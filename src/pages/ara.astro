---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Ara"
  description="Kanada Gazetesi arşivinde haber, rehber ve analiz arayın."
  path="/ara"
>
  <Fragment slot="head">
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <meta name="robots" content="noindex, follow" />
  </Fragment>

  <section class="wrap--narrow search">
    <p class="kicker">Arşiv</p>
    <h1 class="search__title">Ara</h1>
    <p class="search__lede meta">
      Göç, yerleşim, toplum ve yaşam üzerine tüm yazılarda arama yapın.
    </p>
    <div id="search" class="search__box"></div>
    <noscript>
      <p class="search__noscript">
        Arama için JavaScript gereklidir. Bölümlere
        <a href="/">ana sayfadan</a> göz atabilirsiniz.
      </p>
    </noscript>
  </section>

  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function () {
      if (typeof PagefindUI === 'undefined') return;
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        translations: {
          placeholder: 'Ara…',
          clear_search: 'Temizle',
          load_more: 'Daha fazla sonuç',
          search_label: 'Bu sitede ara',
          filters_label: 'Filtreler',
          zero_results: '"[SEARCH_TERM]" için sonuç bulunamadı',
          many_results: '"[SEARCH_TERM]" için [COUNT] sonuç',
          one_result: '"[SEARCH_TERM]" için [COUNT] sonuç',
          alt_search:
            '"[SEARCH_TERM]" için sonuç yok; bunun yerine "[DIFFERENT_TERM]" gösteriliyor',
          search_suggestion: '"[SEARCH_TERM]" için sonuç yok. Şunları deneyin:',
          searching: '"[SEARCH_TERM]" aranıyor…',
        },
      });

      // URL'deki ?q= parametresini arama kutusuna aktar
      const q = new URLSearchParams(window.location.search).get('q');
      if (q) {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    });
  </script>
</BaseLayout>

<style>
  .search {
    padding-top: clamp(1.5rem, 1rem + 2vw, 3rem);
    min-height: 60vh;
  }
  .search__title {
    font-size: var(--step-3);
    margin: 0.4rem 0 0.6rem;
  }
  .search__lede {
    margin-bottom: 1.8rem;
  }
  .search__box {
    --pagefind-ui-primary: var(--crimson-500);
    --pagefind-ui-text: var(--ink-900);
    --pagefind-ui-background: var(--paper-000);
    --pagefind-ui-border: var(--ink-200);
    --pagefind-ui-tag: var(--paper-100);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-2);
    --pagefind-ui-font: var(--font-sans);
  }
  .search__noscript {
    margin-top: 1.5rem;
    color: var(--ink-soft);
  }
</style>
