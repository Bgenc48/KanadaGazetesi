---
import Logo from './Logo.astro';
import { sections } from '../data/sections';

const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));

const links = [
  { href: '/', label: 'Anasayfa' },
  ...sections.map((s) => ({ href: `/bolum/${s.id}`, label: s.name })),
];
---

<nav class="sitenav" aria-label="Bölümler">
  <div class="wrap sitenav__inner">
    <a href="/" class="sitenav__brand" aria-label="Ana sayfa">
      <Logo size={26} />
      <span>Kanada&nbsp;Gazetesi</span>
    </a>

    <ul class="sitenav__list">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={['sitenav__link', { 'is-active': isActive(l.href) }]}
              aria-current={isActive(l.href) ? 'page' : undefined}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a href="/hakkimizda" class="sitenav__about">Hakkımızda</a>

    <a href="/ara" class="sitenav__icon" aria-label="Ara" title="Ara">
      <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"
        ></circle>
        <line
          x1="16.5"
          y1="16.5"
          x2="21"
          y2="21"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></line>
      </svg>
    </a>

    <button
      type="button"
      class="sitenav__icon sitenav__theme"
      aria-label="Karanlık/aydınlık tema"
      title="Tema değiştir"
      data-theme-toggle
    >
      <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
        <circle cx="12" cy="12" r="4.5" fill="currentColor"></circle>
        <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="12" y1="1.5" x2="12" y2="4"></line>
          <line x1="12" y1="20" x2="12" y2="22.5"></line>
          <line x1="1.5" y1="12" x2="4" y2="12"></line>
          <line x1="20" y1="12" x2="22.5" y2="12"></line>
          <line x1="4.2" y1="4.2" x2="6" y2="6"></line>
          <line x1="18" y1="18" x2="19.8" y2="19.8"></line>
          <line x1="4.2" y1="19.8" x2="6" y2="18"></line>
          <line x1="18" y1="6" x2="19.8" y2="4.2"></line>
        </g>
      </svg>
      <svg
        class="icon-moon"
        viewBox="0 0 24 24"
        width="18"
        height="18"
        aria-hidden="true"
      >
        <path d="M20 14.5A8 8 0 0 1 9.5 4a7 7 0 1 0 10.5 10.5z" fill="currentColor"
        ></path>
      </svg>
    </button>
  </div>
</nav>

<script is:inline>
  (function () {
    const btn = document.querySelector('[data-theme-toggle]');
    if (!btn) return;
    btn.addEventListener('click', function () {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch {
        /* yoksay */
      }
      const meta = document.querySelector('meta[name="theme-color"]');
      if (meta) meta.setAttribute('content', next === 'dark' ? '#141009' : '#b41e26');
    });
  })();
</script>

<style>
  .sitenav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 92%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-top: 1px solid var(--rule);
    border-bottom: 2px solid var(--ink);
  }
  .sitenav__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: 3rem;
  }
  .sitenav__brand {
    display: none;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.98rem;
    flex: none;
    white-space: nowrap;
  }
  .sitenav__brand:hover {
    text-decoration: none;
  }
  .sitenav__list {
    display: flex;
    align-items: stretch;
    gap: 0.2rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .sitenav__list::-webkit-scrollbar {
    display: none;
  }
  .sitenav__link {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    white-space: nowrap;
    padding: 0.9rem 0.7rem 0.8rem;
    display: inline-flex;
    align-items: center;
    border-bottom: 3px solid transparent;
    color: var(--ink-soft);
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .sitenav__link:hover {
    color: var(--ink);
    text-decoration: none;
    border-bottom-color: var(--rule-strong);
  }
  .sitenav__link.is-active {
    color: var(--crimson);
    border-bottom-color: var(--crimson);
  }
  .sitenav__about {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--crimson);
    flex: none;
  }
  .sitenav__icon {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border: 1px solid var(--rule);
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--ink-soft);
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }
  .sitenav__icon:hover {
    color: var(--crimson);
    border-color: var(--crimson);
    text-decoration: none;
  }
  /* Tema simgesi: aktif temaya göre güneş/ay göster */
  .sitenav__theme .icon-moon {
    display: none;
  }
  :global([data-theme='dark']) .sitenav__theme .icon-sun {
    display: none;
  }
  :global([data-theme='dark']) .sitenav__theme .icon-moon {
    display: block;
  }

  @media (min-width: 880px) {
    .sitenav__brand {
      display: inline-flex;
    }
    .sitenav__list {
      flex: 0 1 auto;
      justify-content: center;
      margin-inline: auto;
    }
  }
  @media (max-width: 560px) {
    .sitenav__about {
      display: none;
    }
  }
</style>
