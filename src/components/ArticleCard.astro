---
import type { Article } from '../utils/format';
import { deriveExcerpt } from '../utils/format';
import { getSection } from '../data/sections';
import Kicker from './Kicker.astro';
import Byline from './Byline.astro';

export interface Props {
  article: Article;
  variant?: 'feature' | 'standard' | 'compact' | 'list';
  showExcerpt?: boolean;
}
const { article, variant = 'standard', showExcerpt = true } = Astro.props;
const { title, heroImage, heroAlt, section } = article.data;
const href = `/makale/${article.id}`;
const meta = getSection(section);
const accent = meta ? `var(${meta.accent})` : 'var(--crimson)';
const excerpt = deriveExcerpt(article, variant === 'feature' ? 200 : 130);
const showImage = variant === 'feature' || variant === 'standard' || variant === 'list';
---
<article class:list={['card', `card--${variant}`]}>
  {
    showImage && (
      <a class="card__media" href={href} tabindex="-1" aria-hidden="true">
        {heroImage ? (
          <img src={heroImage} alt={heroAlt ?? ''} loading="lazy" decoding="async" />
        ) : (
          <span class="card__media-empty">
            <svg viewBox="0 0 100 100" width="32%" aria-hidden="true">
              <mask id={`kgcard-${article.id}`}><rect width="100" height="100" fill="#fff" /><circle cx="63" cy="50" r="24.5" fill="#000" /></mask>
              <circle cx="50" cy="50" r="31" fill="currentColor" mask={`url(#kgcard-${article.id})`} />
              <polygon fill="currentColor" points="72,40 74.35,46.76 81.51,46.91 75.80,51.24 77.88,58.09 72,54 66.12,58.09 68.20,51.24 62.49,46.91 69.65,46.76" />
            </svg>
          </span>
        )}
      </a>
    )
  }
  <div class="card__body">
    <Kicker section={section} />
    <h3 class="card__title">
      <a href={href}>{title}</a>
    </h3>
    {showExcerpt && variant !== 'compact' && <p class="card__excerpt">{excerpt}</p>}
    <Byline article={article} withReadingTime={variant === 'feature'} />
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .card__media {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--paper-2);
    border-radius: var(--radius);
  }
  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Duotone-leaning: hafif doygunluk düşüşü + kontrast */
    filter: saturate(0.92) contrast(1.02);
    transition: transform 0.5s var(--ease-out);
  }
  .card:hover .card__media img {
    transform: scale(1.03);
  }
  /* Boş görsel: gazete kâğıdı taraması + soluk hilal filigranı */
  .card__media-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--ink-300);
    border: 1px solid var(--ink-100);
    border-radius: var(--radius-2);
    background:
      repeating-linear-gradient(135deg, rgba(22, 18, 13, 0.035) 0 1px, transparent 1px 7px),
      linear-gradient(160deg, var(--paper-200), var(--paper-300));
  }
  .card__media-empty svg { max-width: 64px; opacity: 0.55; }
  .card__title {
    font-size: var(--step-1);
    line-height: 1.08;
  }
  .card__title a::after {
    /* tüm kartı tıklanabilir yapan görünmez katman */
    content: '';
    position: absolute;
    inset: 0;
  }
  .card__excerpt {
    color: var(--ink-soft);
    font-size: var(--step--1);
    line-height: 1.55;
  }
  .card__body {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* feature: daha büyük başlık */
  .card--feature .card__title { font-size: var(--step-2); }
  .card--feature .card__excerpt { font-size: var(--step-0); }

  /* compact: görselsiz, ince ayraçlı */
  .card--compact { gap: 0.4rem; }
  .card--compact .card__title { font-size: var(--step-0); font-weight: 600; }

  /* list: küçük yatay küçük resim + başlık */
  .card--list {
    flex-direction: row;
    align-items: flex-start;
    gap: 0.9rem;
  }
  .card--list .card__media {
    flex: none;
    width: 92px;
    aspect-ratio: 1 / 1;
  }
  .card--list .card__title { font-size: 1rem; line-height: 1.15; }
  .card--list .card__body { gap: 0.35rem; }
</style>
