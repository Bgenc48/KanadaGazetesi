---
/**
 * Kanada Gazetesi logomark — hilal + yıldız (Türkiye),
 * iki bayrağın ortak rengi kızılda.
 */
export interface Props {
  size?: number;
  color?: string;
  title?: string;
}
const { size = 40, color = 'var(--crimson)', title = 'Kanada Gazetesi' } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 100 100"
  role="img"
  aria-label={title}
  class="kg-logo"
>
  <defs>
    <mask id={`kg-crescent-${size}`}>
      <rect width="100" height="100" fill="white" />
      <circle cx="63" cy="50" r="24.5" fill="black" />
    </mask>
  </defs>
  <circle cx="50" cy="50" r="31" fill={color} mask={`url(#kg-crescent-${size})`} />
  <polygon
    points="72,40 74.35,46.76 81.51,46.91 75.80,51.24 77.88,58.09 72,54 66.12,58.09 68.20,51.24 62.49,46.91 69.65,46.76"
    fill={color}
  />
</svg>
