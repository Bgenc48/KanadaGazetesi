---
/**
 * Tag — konu çipi (makale altı, konu rayları). Hash önekli, sakin pill.
 */
export interface Props {
  href?: string;
  active?: boolean;
  class?: string;
}
const { href = '#', active = false, class: className } = Astro.props;
const cls = ['ktag', active ? 'is-active' : '', className].filter(Boolean).join(' ');
---

<a class={cls} href={href}><span class="ktag__hash">#</span><slot /></a>

<style>
  .ktag {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-sans);
    font-weight: var(--w-semibold);
    font-size: 0.8125rem;
    letter-spacing: 0.01em;
    text-decoration: none;
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--ink-200);
    color: var(--ink-700);
    background: transparent;
    transition:
      background var(--dur) var(--ease-out),
      color var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out);
  }
  .ktag__hash {
    color: var(--crimson-500);
    margin-right: 0.15em;
  }
  .ktag:hover {
    border-color: var(--ink-900);
    color: var(--ink-900);
    text-decoration: none;
  }
  .ktag.is-active {
    background: var(--ink-900);
    color: var(--paper-050);
    border-color: var(--ink-900);
  }
  .ktag.is-active .ktag__hash {
    color: var(--crimson-400);
  }
</style>
