---
import type { Article } from '../utils/format';
import { deriveExcerpt } from '../utils/format';
import { getSection } from '../data/sections';
import Kicker from './Kicker.astro';
import Byline from './Byline.astro';

export interface Props {
  article: Article;
}
const { article } = Astro.props;
const { title, deck, heroImage, heroAlt, heroCredit, section } = article.data;
const href = `/makale/${article.id}`;
const meta = getSection(section);
const accent = meta ? `var(${meta.accent})` : 'var(--crimson)';
const excerpt = deck ?? deriveExcerpt(article, 240);
---
<article class="lead">
  <a class="lead__media" href={href} tabindex="-1" aria-hidden="true">
    {heroImage ? (
      <img src={heroImage} alt={heroAlt ?? ''} fetchpriority="high" decoding="async" />
    ) : (
      <span class="lead__media-empty">
        <svg viewBox="0 0 100 100" width="22%" aria-hidden="true">
          <mask id={`kglead-${article.id}`}><rect width="100" height="100" fill="#fff" /><circle cx="63" cy="50" r="24.5" fill="#000" /></mask>
          <circle cx="50" cy="50" r="31" fill="currentColor" mask={`url(#kglead-${article.id})`} />
          <polygon fill="currentColor" points="72,40 74.35,46.76 81.51,46.91 75.80,51.24 77.88,58.09 72,54 66.12,58.09 68.20,51.24 62.49,46.91 69.65,46.76" />
        </svg>
      </span>
    )}
    {heroCredit && <span class="lead__credit">{heroCredit}</span>}
  </a>

  <div class="lead__body">
    <Kicker section={section} />
    <h2 class="lead__title">
      <a href={href}>{title}</a>
    </h2>
    <p class="lead__deck">{excerpt}</p>
    <Byline article={article} />
    <a href={href} class="lead__more">Yazının tamamını oku →</a>
  </div>
</article>

<style>
  .lead {
    display: grid;
    gap: 1.4rem;
  }
  .lead__media {
    display: block;
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--paper-2);
    border-radius: var(--radius);
  }
  .lead__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.02);
    transition: transform 0.6s var(--ease-out);
  }
  .lead:hover .lead__media img { transform: scale(1.02); }
  .lead__media-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--ink-300);
    border: 1px solid var(--ink-100);
    border-radius: var(--radius-2);
    background:
      repeating-linear-gradient(135deg, rgba(22, 18, 13, 0.035) 0 1px, transparent 1px 7px),
      linear-gradient(160deg, var(--paper-200), var(--paper-300));
  }
  .lead__media-empty svg { max-width: 110px; opacity: 0.5; }
  .lead__credit {
    position: absolute;
    right: 0.5rem;
    bottom: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--paper);
    background: color-mix(in srgb, var(--ink) 70%, transparent);
    padding: 0.25em 0.5em;
    border-radius: 2px;
  }
  .lead__body {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .lead__title {
    font-size: var(--step-4);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .lead__deck {
    font-size: var(--step-1);
    line-height: 1.4;
    color: var(--ink-soft);
    font-family: var(--font-serif);
    max-width: 46ch;
  }
  .lead__more {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--crimson);
    margin-top: 0.2rem;
  }

  @media (min-width: 880px) {
    .lead {
      grid-template-columns: 1.25fr 1fr;
      gap: 2.2rem;
      align-items: center;
    }
  }
</style>
