---
import '../styles/global.css';
import Masthead from '../components/Masthead.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';

export interface Props {
  title?: string;
  description?: string;
  /** OG görseli (mutlak veya /images/...) */
  image?: string;
  /** og:type — makalelerde 'article' */
  type?: 'website' | 'article';
  /** Sayfaya özel canonical yolu (örn. /makale/...) */
  path?: string;
  /** <head> içine ek içerik (JSON-LD vb.) */
  noMasthead?: boolean;
}

const {
  title,
  description = site.description,
  image = '/images/og-default.svg',
  type = 'website',
  path = Astro.url.pathname,
  noMasthead = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.tagline}`;
const canonical = new URL(path, site.url).href;
const ogImage = new URL(image, site.url).href;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#c1121f" />

    <!-- İkon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="tr_CA" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title ?? site.name} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ?? site.name} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Yazı tipleri: Playfair Display (manşet), Source Serif 4 (gövde), Archivo (etiket) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Archivo+Narrow:wght@500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,600&display=swap"
    />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} — RSS`}
      href="/rss.xml"
    />

    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">İçeriğe geç</a>
    {!noMasthead && <Masthead />}
    <SiteNav />
    <main id="main">
      <slot />
    </main>
    <Footer year={year} />
  </body>
</html>
